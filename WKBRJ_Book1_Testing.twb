              <calculation class='tableau' formula='SUM&#13;&#10;(       &#13;&#10;   IF&#13;&#10;    YEAR([date]) = [Parameters].[Parameter 1]&#13;&#10;    THEN &#13;&#10;    [number_of_casualties]&#13;&#10;   END&#13;&#10;)' />
